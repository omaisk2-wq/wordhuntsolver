---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  schema?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
}

const { title, description, path, ogImage, schema, noindex } = Astro.props;

const siteWideSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Word Hunt Solver",
    url: "https://www.wordhuntsolvers.com/",
    logo: "https://www.wordhuntsolvers.com/favicon.svg",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Word Hunt Solver",
    url: "https://www.wordhuntsolvers.com/",
  },
];

const pageSchema = Array.isArray(schema) ? schema : schema ? [schema] : [];
const allSchema = [...siteWideSchema, ...pageSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo title={title} description={description} path={path} ogImage={ogImage} schema={allSchema} noindex={noindex} />
    <script is:inline>
      // Runs before paint to avoid a flash of the wrong theme.
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const dark = stored ? stored === "dark" : prefersDark;
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
