---
import ThemeToggle from "./ThemeToggle.tsx";

const isEvolverPage = Astro.url.pathname.startsWith("/evolver");
const toggleHref = isEvolverPage ? "/" : "/evolver";
const toggleLabel = isEvolverPage ? "Solver" : "Evolver";
---

<header class="sticky top-0 z-40 border-b border-brand-100 bg-white/90 backdrop-blur dark:border-brand-700 dark:bg-brand-900/90">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2 whitespace-nowrap font-extrabold text-gray-900 dark:text-white">
      <img
        src="/images/word-hunt-solver-logo.webp"
        alt="Word Hunt Solver Logo"
        width="32"
        height="32"
        class="flex-none rounded-lg"
      />
      <span class="text-base sm:text-lg">Word Hunt Solver</span>
    </a>

    <div class="flex flex-none items-center gap-3">
      <a href={toggleHref} class="inline-flex flex-none rounded-lg border border-brand-200 px-3 py-1.5 text-sm font-semibold text-gray-900 hover:bg-brand-50 dark:border-brand-700 dark:text-accent-400 dark:hover:bg-brand-800">
        {toggleLabel}
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
