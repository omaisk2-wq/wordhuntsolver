---
import Layout from "../../layouts/Layout.astro";

const guides = [
  { href: "/guides/word-hunt-cheat", title: "Word Hunt Cheat", group: "Grid Games", desc: "Every GamePigeon Word Hunt answer, scoring rules, and whether a solver counts as cheating." },
  { href: "/guides/free-word-finder", title: "Free Word Finder", group: "Letter and Tile Games", desc: "Find words from any loose set of letters for Scrabble, Words With Friends, and more." },
  { href: "/guides/wordscapes-help", title: "Wordscapes Help", group: "Daily Puzzle Games", desc: "The full cheat sheet and an explanation of bonus words." },
];
---

<Layout
  title="Word Game Guides: How to Solve Every Puzzle"
  description="Browse simple guides for Word Hunt, Wordle, Jumble, Wordscapes and more word games. Pick your puzzle and get instant help."
  path="/guides"
>
  <section class="mx-auto max-w-3xl px-4 pt-10 pb-6 text-center sm:pt-16">
    <h1 class="text-3xl font-extrabold text-brand-700 dark:text-white sm:text-4xl">
      Word Game Guides: How to Solve Every Puzzle
    </h1>
    <p class="mt-3 text-center text-gray-600 dark:text-gray-300 text-sm">
      This page is a directory of every guide on wordhuntsolvers.com. Each guide answers one specific
      problem, so you can jump straight to the game you are playing.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-6">
    <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">Browse Guides By Game</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      {guides.map((g) => (
        <a href={g.href} class="card block text-center transition hover:-translate-y-1 hover:shadow-md">
          <p class="text-xs font-semibold uppercase tracking-wide text-accent-600 dark:text-accent-400">{g.group}</p>
          <h3 class="mt-1 font-bold text-gray-900 dark:text-white">{g.title}</h3>
          <p class="mt-2 text-gray-600 dark:text-gray-300 text-sm">{g.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="card-cta flex flex-col items-center gap-4 bg-accent-500 text-center text-white dark:bg-accent-600">
      <h2 class="text-2xl font-bold">Not Sure Where to Start?</h2>
      <p class="max-w-2xl text-white/90">Try the Word Hunt Solver tool first, then come back for the guide that matches your game.</p>
      <a href="/" class="btn-cta">Try the Word Hunt Solver</a>
    </div>
  </section>
</Layout>
