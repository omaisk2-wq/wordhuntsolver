---
import Layout from "../../layouts/Layout.astro";

const faqs = [
  { q: "Why do some words not count in Wordscapes?", a: "They may be valid dictionary words but only qualify as bonus words in that specific level, not part of the main crossword answer." },
  { q: "Is this an official Wordscapes tool?", a: "No, this is an independent tool and is not affiliated with or endorsed by PeopleFun, the maker of Wordscapes." },
  { q: "Does it work for every level?", a: "It checks against a broad English dictionary, which covers the vast majority of Wordscapes levels." },
  { q: "Is it free to use?", a: "Yes, wordscapes help on this site is completely free." },
  { q: "Can I search by starting letter?", a: "Yes, use the starts with filter to narrow your results." },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://www.wordhuntsolvers.com/" },
      { "@type": "ListItem", position: 2, name: "Guides", item: "https://www.wordhuntsolvers.com/guides" },
      { "@type": "ListItem", position: 3, name: "Wordscapes Help", item: "https://www.wordhuntsolvers.com/guides/wordscapes-help" },
    ],
  },
];
---

<Layout
  title="Wordscapes Help: Answers for Every Level"
  description="Stuck in Wordscapes? Get instant wordscapes help and a full cheat sheet answer for every level, plus tips on bonus words."
  path="/guides/wordscapes-help"
  schema={schema}
  ogImage="/images/wordscapes-help.webp"
>
  <article class="mx-auto max-w-3xl px-4 py-10 sm:py-16">
    <nav aria-label="Breadcrumb" class="mb-4 text-xs text-brand-400 dark:text-brand-300">
      <a href="/" class="hover:text-headline">Home</a> / <a href="/guides" class="hover:text-headline">Guides</a> / <span>Wordscapes Help</span>
    </nav>
    <h1 class="text-3xl font-extrabold text-headline dark:text-headline-dark sm:text-4xl">
      Wordscapes Help: Cheats and Answers for Every Level
    </h1>
    <p class="mt-4 text-xs italic text-brand-400 dark:text-brand-300">Written by admin</p>

    <img
      src="/images/wordscapes-help.webp"
      alt="Wordscapes Help"
      width="1680"
      height="944"
      class="mt-6 w-full rounded-2xl border border-brand-100 dark:border-brand-700"
    />

    <h2 class="mt-8 text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">How to Use This Wordscapes Help Tool</h2>
    <p class="mt-3 text-gray-600 dark:text-gray-300 text-sm">
      Wordscapes help means typing the letters shown in your puzzle circle into a solver to get every valid
      word for that level instantly. Enter your letters, press solve, and you will see every word you can
      spell, sorted from longest to shortest.
    </p>

    <h2 class="mt-8 text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">Understanding Wordscapes Bonus Words</h2>
    <p class="mt-3 text-gray-600 dark:text-gray-300 text-sm">
      Bonus words are valid words that do not fit in the crossword style answer grid, but still earn you
      coins. A word can be real and spellable from your letters yet still count only as a bonus word, not
      a main puzzle answer, this is by game design, not a solver error.
    </p>

    <h2 class="mt-8 text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">More Word Tools On This Site</h2>
    <p class="mt-3 text-gray-600 dark:text-gray-300 text-sm">
      For a different kind of grid puzzle, try our <a href="/" class="anchor-link">word hunt solver</a>, or read the
      <a href="/guides/word-hunt-cheat" class="anchor-link">word hunt cheat</a> guide. If you just need words from loose letters, the
      <a href="/guides/free-word-finder" class="anchor-link">free word finder</a> works for that too.
    </p>

    <h2 class="mt-8 text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">FAQs About Wordscapes Help</h2>
    <div class="mt-4 space-y-3">
      {faqs.map((f) => (
        <details class="card group">
          <summary class="flex cursor-pointer items-center justify-between">
            <h3 class="font-bold text-gray-900 dark:text-white">{f.q}</h3>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-4 h-5 w-5 flex-none text-secondary-600 transition-transform group-open:rotate-180"><path d="M6 9l6 6 6-6" /></svg>
          </summary>
          <p class="mt-2 text-gray-600 dark:text-gray-300 text-sm">{f.a}</p>
        </details>
      ))}
    </div>

    <div class="card-cta mt-10 flex flex-col items-center gap-4 text-center">
      <h2 class="text-2xl font-bold">Get Wordscapes Help Right Now</h2>
      <p class="max-w-xl text-brand-600">
        Wordscapes help should get you unstuck in seconds, not send you searching through ten different
        sites. Enter your letters, get your answer, and get back to your streak.
      </p>
      <a href="/" class="btn-cta">Get Wordscapes Help Now</a>
    </div>
  </article>
</Layout>
